SESSION_SECRET=
# Admin Dashboard configuration
ADMIN_EMAIL=hligon@getsparqd.com
ADMIN_PASSWORD=
# SESSION_SECRET=

# Optional: change ports/paths
PORT=8787

# Store session files in the project (Windows Temp can trigger EPERM rename failures)
SESSIONS_DIR=./sessions

ENABLE_EXPORTS=true

# Cloudflare Worker integration
# Set this to your deployed Worker or custom-domain origin when the local admin
# should proxy gallery, YouTube, and support requests through Cloudflare.
# Example: https://mmmbc.example.workers.dev or https://mmmbc.com
WORKER_ORIGIN=

# Cloudflare Access service token for local admin -> Worker proxy requests.
# Required only when your Worker is protected by Cloudflare Access.
# These same values should also exist as Worker secrets in Cloudflare.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Support email defaults used by the local admin and Worker-backed support flow.
SUPPORT_TO_EMAIL=support@example.com
SUPPORT_FROM_EMAIL=no-reply@example.com
SUPPORT_FROM_NAME=MMMBC Admin Support

# Optional shared token for non-browser support API callers.
SUPPORT_API_TOKEN=

# Cloudflare Worker-side settings are configured in wrangler.jsonc / Worker secrets,
# not in this local admin file. Keep those in sync separately:
# - ADMIN_ALLOW_EMAILS
# - CANONICAL_HOST
# - ALLOW_SERVICE_TOKEN_ADMIN
# - DEV_BYPASS_AUTH
# - SUPPORT_EMAIL_DESTINATION

# Google Sign-In (required for Google admin auth)
# Create a Web OAuth client in Google Cloud Console and paste the client ID below.
# Google Sign-In works for approved Google accounts, including @gmail.com and
# Google Workspace/custom-domain accounts. It is not limited to gmail.com.
GOOGLE_CLIENT_ID=
# Comma-separated approved Google emails for first-time admin account creation.
GOOGLE_ALLOWED_EMAILS=